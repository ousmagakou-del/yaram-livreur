<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Push Notifications capability
         "development" pour TestFlight / dev local
         "production" pour App Store release
         Apple gère automatiquement le switch entre les deux selon le build type
         tant que la clé APNs OneSignal couvre "Sandbox & Production" -->
    <key>aps-environment</key>
    <string>production</string>
    <!-- Universal Links : permet aux URLs https://yaram.app/order/* d'ouvrir
         l'app au lieu de Safari quand l'app est installée.
         Nécessite que /.well-known/apple-app-site-association soit hébergé
         sur yaram.app avec le bon Team ID + bundle ID. -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:yaram.app</string>
    </array>
</dict>
</plist>
