<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Push Notifications capability
         "development" pour TestFlight / dev local
         "production" pour App Store release
         Apple gère automatiquement le switch entre les deux selon le build type
         tant que la clé APNs OneSignal couvre "Sandbox & Production" -->
    <key>aps-environment</key>
    <string>production</string>

    <!-- Sign in with Apple : obligatoire car YARAM propose Google OAuth.
         Apple rejette toute app qui offre une connexion sociale sans
         proposer aussi Sign in with Apple (App Store Review Guideline 4.8).
         Le code JS / flow Supabase est traité séparément. -->
    <key>com.apple.developer.applesignin</key>
    <array>
        <string>Default</string>
    </array>

    <!-- Universal Links : AASA déployé sur https://yaram.app/.well-known/apple-app-site-association.
         Permet aux liens https://yaram.app/... d'ouvrir directement l'app
         (deep links produits, reset password, magic links Supabase, etc.). -->
    <key>com.apple.developer.associated-domains</key>
    <array>
        <string>applinks:yaram.app</string>
    </array>
</dict>
</plist>
