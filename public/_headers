# Content-Type correct pour Apple App Site Association
# Apple REFUSE l'AASA si pas servi en application/json
/.well-known/apple-app-site-association
  Content-Type: application/json
  Cache-Control: public, max-age=3600

# Pareil pour l'Android Asset Links (Universal Links Android plus tard)
/.well-known/assetlinks.json
  Content-Type: application/json
  Cache-Control: public, max-age=3600
